# JARVIS Environment Variables — Example
# Copy this file to .env and fill in your values.

# Required: Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Home Assistant (only needed if smart_home.enabled: true in config.yaml)
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=your_long_lived_access_token_here

# Optional: override platform detection (set to "rpi" on Raspberry Pi)
# JARVIS_PLATFORM=rpi
